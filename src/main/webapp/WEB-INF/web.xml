<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="https://jakarta.ee/xml/ns/jakartaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="https://jakarta.ee/xml/ns/jakartaee 
         https://jakarta.ee/xml/ns/jakartaee/web-app_5_0.xsd"
         version="5.0">

    <display-name>Meu App Web</display-name>
    <description>App web básica com Servlets</description>

    <!-- Welcome file (página inicial) -->
    <welcome-file-list>
        <welcome-file>index.html</welcome-file>
        <welcome-file>index.jsp</welcome-file>
    </welcome-file-list>

    <!-- Encoding padrão UTF-8 -->
    <filter>
        <filter-name>CharacterEncodingFilter</filter-name>
        <filter-class>br.com.agnellovinheria.filter.CharacterEncodingFilter</filter-class>
        <init-param>
            <param-name>encoding</param-name>
            <param-value>UTF-8</param-value>
        </init-param>
    </filter>
    <filter-mapping>
        <filter-name>CharacterEncodingFilter</filter-name>
        <url-pattern>/*</url-pattern>
    </filter-mapping>

    <!-- TenantFilter deve rodar ANTES de AuthFilter para que o atributo "vinheriaId"
         esteja disponível quando AuthFilter for executado em rotas /admin/*. -->
    <filter>
        <filter-name>TenantFilter</filter-name>
        <filter-class>br.com.agnellovinheria.filter.TenantFilter</filter-class>
    </filter>
    <filter-mapping>
        <filter-name>TenantFilter</filter-name>
        <url-pattern>/*</url-pattern>
    </filter-mapping>

    <filter>
        <filter-name>AuthFilter</filter-name>
        <filter-class>br.com.agnellovinheria.filter.AuthFilter</filter-class>
    </filter>
    <filter-mapping>
        <filter-name>AuthFilter</filter-name>
        <url-pattern>/admin/*</url-pattern>
    </filter-mapping>

    <!-- =========================================================
         Admin Panel Servlets
         ========================================================= -->
    <servlet>
        <servlet-name>DashboardServlet</servlet-name>
        <servlet-class>br.com.agnellovinheria.servlet.admin.DashboardServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>DashboardServlet</servlet-name>
        <url-pattern>/admin/dashboard</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>DashboardServlet</servlet-name>
        <url-pattern>/admin/</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>CatalogoServlet</servlet-name>
        <servlet-class>br.com.agnellovinheria.servlet.admin.CatalogoServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>CatalogoServlet</servlet-name>
        <url-pattern>/admin/catalogo</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>PedidosServlet</servlet-name>
        <servlet-class>br.com.agnellovinheria.servlet.admin.PedidosServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>PedidosServlet</servlet-name>
        <url-pattern>/admin/pedidos</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>RelatoriosServlet</servlet-name>
        <servlet-class>br.com.agnellovinheria.servlet.admin.RelatoriosServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>RelatoriosServlet</servlet-name>
        <url-pattern>/admin/relatorios</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>QrCodeServlet</servlet-name>
        <servlet-class>br.com.agnellovinheria.servlet.admin.QrCodeServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>QrCodeServlet</servlet-name>
        <url-pattern>/admin/qrcode</url-pattern>
    </servlet-mapping>

    <!-- =========================================================
         Custom Error Pages
         ========================================================= -->
    <error-page>
        <error-code>404</error-code>
        <location>/WEB-INF/views/admin/errors/error-404.jsp</location>
    </error-page>
    <error-page>
        <error-code>500</error-code>
        <location>/WEB-INF/views/admin/errors/error-500.jsp</location>
    </error-page>

</web-app>