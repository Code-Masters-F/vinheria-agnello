/* ============================================================
   VINHERIA AGNELLO — Admin Components + Utilities
   All reusable component styles and helper utilities.
   No hard-coded colours — all values use CSS variables.
   ============================================================ */

/* ─── Material Icons helper ───────────────────────────────── */
.nav-icon {
    font-family: 'Material Icons Round', sans-serif;
    font-style: normal;
    font-weight: normal;
    font-size: 1.25rem;
    line-height: 1;
    letter-spacing: normal;
    text-transform: none;
    display: inline-block;
    white-space: nowrap;
    word-wrap: normal;
    direction: ltr;
    -webkit-font-feature-settings: 'liga';
    font-feature-settings: 'liga';
    -webkit-font-smoothing: antialiased;
    vertical-align: middle;
    user-select: none;
}

/* ─── Cards ───────────────────────────────────────────────── */
.card {
    background-color: var(--color-surface);
    border-radius: var(--radius-lg);
    border: 1px solid var(--color-border-subtle);
    box-shadow: var(--shadow-sm);
    overflow: hidden;
    transition: var(--transition-fast);
}

.card:hover {
    box-shadow: var(--shadow-md);
}

.card-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: var(--spacing-md) var(--spacing-lg);
    border-bottom: 1px solid var(--color-border-subtle);
    gap: var(--spacing-md);
}

.card-title {
    margin: 0;
    font-size: 1rem;
    font-weight: 600;
    color: var(--color-text-primary);
    display: flex;
    align-items: center;
    gap: var(--spacing-sm);
}

.card-body {
    padding: var(--spacing-lg);
}

/* ─── Metric cards ────────────────────────────────────────── */
.metric-card {
    background-color: var(--color-surface);
    border-radius: var(--radius-lg);
    border: 1px solid var(--color-border-subtle);
    box-shadow: var(--shadow-sm);
    padding: var(--spacing-lg);
    display: flex;
    flex-direction: column;
    gap: var(--spacing-xs);
    transition: var(--transition-fast);
}

.metric-card:hover {
    box-shadow: var(--shadow-md);
    transform: translateY(-1px);
}

.metric-icon {
    font-family: 'Material Icons Round', sans-serif;
    font-style: normal;
    font-size: 1.5rem;
    line-height: 1;
    width: 2.5rem;
    height: 2.5rem;
    border-radius: var(--radius-md);
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: var(--spacing-xs);
    user-select: none;
}

/* Metric icon colour variants */
.metric-icon.purple {
    background-color: var(--color-accent-purple-light);
    color: var(--color-accent-purple);
}
.metric-icon.blue {
    background-color: var(--color-accent-blue-light);
    color: var(--color-accent-blue);
}
.metric-icon.gold {
    background-color: var(--color-accent-gold-light);
    color: var(--color-accent-gold);
}
.metric-icon.green {
    background-color: var(--color-accent-green-light);
    color: var(--color-accent-green);
}
.metric-icon.red {
    background-color: var(--color-accent-red-light);
    color: var(--color-accent-red);
}

.metric-label {
    font-size: 0.8125rem;
    font-weight: 500;
    color: var(--color-text-secondary);
    text-transform: uppercase;
    letter-spacing: 0.04em;
}

.metric-value {
    font-size: 2rem;
    font-weight: 800;
    color: var(--color-text-primary);
    line-height: 1;
}

.metric-sub {
    font-size: 0.75rem;
    color: var(--color-text-muted);
}

/* ─── Grids ───────────────────────────────────────────────── */
.metrics-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(14rem, 1fr));
    gap: var(--spacing-lg);
    margin-bottom: var(--spacing-lg);
}

.panel-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(16rem, 1fr));
    gap: var(--spacing-lg);
    margin-bottom: var(--spacing-lg);
}

.wine-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(17.5rem, 1fr));
    gap: var(--spacing-lg);
}

.form-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--spacing-lg);
}

.form-grid-3 {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--spacing-lg);
}

@media (max-width: 37.5rem) {   /* 600px */
    .form-grid,
    .form-grid-3 {
        grid-template-columns: 1fr;
    }
}

/* ─── Buttons ─────────────────────────────────────────────── */
.btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.375rem;
    padding: 0.5625rem var(--spacing-md);
    border-radius: var(--radius-md);
    font-family: var(--font-family-sans);
    font-weight: 600;
    font-size: 0.875rem;
    cursor: pointer;
    border: 1px solid transparent;
    text-decoration: none;
    transition: var(--transition-fast);
    white-space: nowrap;
    line-height: 1;
}

.btn-sm {
    padding: 0.375rem 0.75rem;
    font-size: 0.8125rem;
}

.btn-lg {
    padding: 0.75rem var(--spacing-lg);
    font-size: 1rem;
}

.btn-primary {
    background-color: var(--color-primary-base);
    color: #ffffff;
}
.btn-primary:hover {
    background-color: var(--color-primary-hover);
}

.btn-secondary {
    background-color: var(--color-surface);
    border-color: var(--color-border-subtle);
    color: var(--color-text-primary);
}
.btn-secondary:hover {
    background-color: var(--color-background-app);
}

.btn-danger {
    background-color: var(--color-surface);
    border-color: var(--color-error);
    color: var(--color-error);
}
.btn-danger:hover {
    background-color: var(--color-error);
    color: #ffffff;
}

.btn-ghost {
    background-color: transparent;
    color: var(--color-text-secondary);
}
.btn-ghost:hover {
    background-color: var(--color-background-app);
    color: var(--color-text-primary);
}

/* ─── Alerts / Flash messages ─────────────────────────────── */
.alert {
    display: flex;
    align-items: center;
    gap: var(--spacing-sm);
    padding: var(--spacing-sm) var(--spacing-md);
    border-radius: var(--radius-md);
    font-size: 0.875rem;
    font-weight: 500;
    margin-bottom: var(--spacing-md);
}

.alert-success {
    background-color: var(--color-success-light);
    color: var(--color-success);
}

.alert-danger {
    background-color: var(--color-error-light);
    color: var(--color-error);
}

.alert-warning {
    background-color: var(--color-warning-light);
    color: var(--color-warning);
}

.alert-info {
    background-color: var(--color-info-light);
    color: var(--color-info);
}

/* ─── Data tables ─────────────────────────────────────────── */
.data-table-wrap {
    overflow-x: auto;
    width: 100%;
}

.data-table {
    width: 100%;
    border-collapse: collapse;
}

.data-table th,
.data-table td {
    padding: 0.75rem var(--spacing-md);
    text-align: left;
    vertical-align: middle;
}

.data-table th {
    border-bottom: 2px solid var(--color-border-subtle);
    color: var(--color-text-secondary);
    font-weight: 600;
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    white-space: nowrap;
    background-color: var(--color-background-app);
}

.data-table td {
    border-bottom: 1px solid var(--color-border-subtle);
    color: var(--color-text-primary);
    font-size: 0.875rem;
}

.data-table tbody tr:last-child td {
    border-bottom: none;
}

.data-table tbody tr:hover {
    background-color: var(--color-background-app);
}

/* ─── Status badges ───────────────────────────────────────── */
.status-badge {
    display: inline-flex;
    padding: 0.1875rem 0.625rem;
    border-radius: var(--radius-full);
    font-size: 0.6875rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    white-space: nowrap;
}

.status-success {
    background-color: var(--color-success-light);
    color: var(--color-success);
}

.status-warning {
    background-color: var(--color-warning-light);
    color: var(--color-warning);
}

.status-error {
    background-color: var(--color-error-light);
    color: var(--color-error);
}

.status-neutral {
    background-color: var(--color-border-subtle);
    color: var(--color-text-secondary);
}

.status-info {
    background-color: var(--color-info-light);
    color: var(--color-info);
}

/* ─── Stock low indicator ─────────────────────────────────── */
.stock-low {
    color: var(--color-error);
    font-weight: 700;
}

/* ─── Forms ───────────────────────────────────────────────── */
.form-group {
    margin-bottom: var(--spacing-md);
}

.form-label {
    display: block;
    margin-bottom: var(--spacing-xs);
    font-weight: 600;
    color: var(--color-text-primary);
    font-size: 0.875rem;
}

.form-control {
    width: 100%;
    padding: 0.5625rem var(--spacing-md);
    border: 1px solid var(--color-border-subtle);
    border-radius: var(--radius-md);
    font-family: var(--font-family-sans);
    font-size: 0.875rem;
    color: var(--color-text-primary);
    background-color: var(--color-surface);
    box-sizing: border-box;
    transition: var(--transition-fast);
}

.form-control:focus {
    outline: none;
    border-color: var(--color-primary-base);
    box-shadow: var(--shadow-focus);
}

.form-hint {
    display: block;
    font-size: 0.75rem;
    color: var(--color-text-muted);
    margin-top: var(--spacing-xs);
}

/* ─── Typography utilities ────────────────────────────────── */
h1, h2, h3, h4, h5, h6 {
    color: var(--color-text-primary);
    margin-top: 0;
    line-height: 1.25;
}

.text-primary { color: var(--color-primary-base) !important; }
.text-muted   { color: var(--color-text-muted)   !important; }
.text-secondary { color: var(--color-text-secondary) !important; }
.text-success { color: var(--color-success)       !important; }
.text-danger  { color: var(--color-error)         !important; }

.fw-600 { font-weight: 600 !important; }
.fw-700 { font-weight: 700 !important; }
.fw-800 { font-weight: 800 !important; }

/* ─── Spacing utilities ───────────────────────────────────── */
.mb-1 { margin-bottom: var(--spacing-xs) !important; }
.mb-2 { margin-bottom: var(--spacing-sm) !important; }
.mb-3 { margin-bottom: var(--spacing-md) !important; }
.mb-4 { margin-bottom: var(--spacing-lg) !important; }
.mt-1 { margin-top:    var(--spacing-xs) !important; }
.mt-2 { margin-top:    var(--spacing-sm) !important; }
.mt-3 { margin-top:    var(--spacing-md) !important; }
.mt-4 { margin-top:    var(--spacing-lg) !important; }

/* ─── Flex utilities ──────────────────────────────────────── */
.d-flex         { display: flex !important; }
.flex           { display: flex; }
.align-center   { align-items: center; }
.justify-between { justify-content: space-between; }
.justify-center { justify-content: center; }
.flex-wrap      { flex-wrap: wrap; }
.flex-col       { flex-direction: column; }
.gap-1          { gap: var(--spacing-xs); }
.gap-2          { gap: var(--spacing-sm); }
.gap-3          { gap: var(--spacing-md); }
.gap-sm         { gap: var(--spacing-sm); }
.gap-md         { gap: var(--spacing-md); }

/* ─── Misc utilities ──────────────────────────────────────── */
.w-full { width: 100%; }
